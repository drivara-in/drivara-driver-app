<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- LaunchTheme is what the OS displays while the Flutter process boots.
         Inherits Theme.Light.NoTitleBar but explicitly opts INTO edge-to-edge
         on Android 15 (API 35+) and asks the system to skip the legacy
         contrast scrim it otherwise paints over the status / nav bars
         (the parameters that triggered the Play Console "deprecated APIs
         for edge-to-edge" warning). Older devices ignore the targetApi
         attrs harmlessly. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
    </style>

    <!-- NormalTheme drives the window background once Flutter takes over;
         same edge-to-edge attrs so the system bars stay transparent under
         the running Flutter UI. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
    </style>
</resources>
